---
import '../styles/global.css';
interface Props { title: string; description: string; lang: 'zh-Hant' | 'ja'; skipLabel: string; }
const { title, description, lang, skipLabel } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f2efe7" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}icons/favicon.svg`} type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{skipLabel}</a>
    <slot />
  </body>
</html>
