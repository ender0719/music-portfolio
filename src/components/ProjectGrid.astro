---
import type { PortfolioContent } from '../data/portfolio';
import ExtensionFooter from './ExtensionFooter.astro';
interface Props {
  items: PortfolioContent['projects']['items'];
  content: PortfolioContent;
  showExtensionRecord?: boolean;
  archive?: boolean;
}
const { items, content, showExtensionRecord = false, archive = false } = Astro.props;
const assetVersion = import.meta.env.PUBLIC_ASSET_VERSION || 'local';
const imageUrl = (src: string) => `${import.meta.env.BASE_URL}${src.slice(1)}?v=${assetVersion}`;
const publicUrl = (src: string) => `${import.meta.env.BASE_URL}${src.slice(1)}`;
---
<div class={`project-grid${archive ? ' archive-grid' : ''}`}>
  {items.map((item, i) => {
    const extension = showExtensionRecord ? item.extensionRecord : undefined;
    const dialogId = `project-video-${i + 1}`;
    const vlog = extension?.type === 'vlog' ? extension : undefined;
    const orientationHint = vlog?.orientation ? ` is-${vlog.orientation}` : '';
    const dialogStyle = vlog?.aspectRatio ? `--video-aspect-ratio:${vlog.aspectRatio}` : undefined;

    return <article class={`project-card project-${i + 1}${extension ? ' has-extension' : ''}${archive ? ' archive-card' : ''}`}>
      <div class="project-image">
        <img src={imageUrl(item.image.src)} alt={item.image.alt} width="1024" height="768" loading="lazy" decoding="async" />
        <span aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
      </div>
      <div class="project-body">
        <div class="project-tags">{item.tags.map((tag) => <span>{tag}</span>)}</div>
        <div class="project-title-row">
          <h3>{item.title}</h3>
          {extension && item.status && <span class="project-status">{item.status}</span>}
        </div>
        {item.subtitle && <p class="project-subtitle">{item.subtitle}</p>}
        <p class={archive ? 'archive-description' : undefined}>{item.description}</p>
        {archive && <dl class="project-details">
          <div><dt>{content.ui.role}</dt><dd>{item.role}</dd></div>
          <div class="archive-takeaway"><dt>{content.ui.archiveTakeaway}</dt><dd>{item.insight}</dd></div>
        </dl>}
        {!archive && !extension && <dl class="project-details">
          <div><dt>{content.ui.role}</dt><dd>{item.role}</dd></div>
          <div><dt>{content.ui.takeaway}</dt><dd>{item.insight}</dd></div>
        </dl>}
        {!archive && extension && <>
          <dl class="project-details project-details-desktop"><div><dt>{content.ui.takeaway}</dt><dd>{item.insight}</dd></div></dl>
          <details class="project-details-mobile"><summary>{content.ui.readTakeaway}<span aria-hidden="true">＋</span></summary><dl class="project-details"><div><dt>{content.ui.takeaway}</dt><dd>{item.insight}</dd></div></dl></details>
        </>}
        {extension && <div class="project-extension">
          <ExtensionFooter record={extension} dialogId={dialogId} />
        </div>}
        {!extension && item.link && <a class={archive ? 'archive-footer' : undefined} href={item.link} target="_blank" rel="noopener noreferrer"><span>{content.ui.learnMore}</span><span aria-hidden="true">↗</span></a>}
      </div>
      {vlog?.status === 'published' && vlog.mediaUrl && <dialog class={`video-dialog is-loading${orientationHint}`} id={dialogId} data-video-dialog data-orientation-hint={vlog.orientation} style={dialogStyle} role="dialog" aria-modal="true" aria-labelledby={`${dialogId}-title`} tabindex="-1">
        <div class="video-dialog-panel">
          <div class="video-dialog-header">
            <div><span>{vlog.date}</span><h3 id={`${dialogId}-title`}>{vlog.title}</h3></div>
            <button type="button" data-video-close aria-label={vlog.closeAction}>×</button>
          </div>
          <div class="video-stage">
            <p class="video-loading" role="status" aria-live="polite">{vlog.loadingLabel}</p>
            <video controls playsinline preload="metadata" data-src={publicUrl(vlog.mediaUrl)} poster={vlog.posterUrl ? imageUrl(vlog.posterUrl) : undefined} tabindex="-1"></video>
          </div>
        </div>
      </dialog>}
    </article>;
  })}
</div>

<script>
  type VideoOrientation = 'portrait' | 'square' | 'landscape';

  const classifyVideoOrientation = (ratio: number): VideoOrientation => {
    if (ratio < 0.9) return 'portrait';
    if (ratio <= 1.1) return 'square';
    return 'landscape';
  };

  document.querySelectorAll<HTMLDialogElement>('[data-video-dialog]').forEach((dialog) => {
    const video = dialog.querySelector<HTMLVideoElement>('video');
    const openButton = document.querySelector<HTMLButtonElement>(`[data-video-open="${dialog.id}"]`);
    const closeButton = dialog.querySelector<HTMLButtonElement>('[data-video-close]');
    const loading = dialog.querySelector<HTMLElement>('.video-loading');

    const applyVideoMetadata = () => {
      if (!video?.videoWidth || !video.videoHeight) return;

      const ratio = video.videoWidth / video.videoHeight;
      const orientation = classifyVideoOrientation(ratio);
      dialog.classList.remove('is-loading', 'is-portrait', 'is-square', 'is-landscape');
      dialog.classList.add(`is-${orientation}`);
      dialog.dataset.videoOrientation = orientation;
      dialog.style.setProperty('--video-aspect-ratio', `${video.videoWidth} / ${video.videoHeight}`);
      video.tabIndex = 0;
      if (loading) loading.hidden = true;
    };

    const closeDialog = () => {
      if (dialog.open) dialog.close();
    };

    video?.addEventListener('loadedmetadata', applyVideoMetadata);

    openButton?.addEventListener('click', () => {
      if (video && !video.src && video.dataset.src) {
        video.src = video.dataset.src;
        video.load();
      }
      dialog.showModal();
      closeButton?.focus();
      if (video && video.readyState >= HTMLMediaElement.HAVE_METADATA) applyVideoMetadata();
    });

    closeButton?.addEventListener('click', closeDialog);
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) closeDialog();
    });
    dialog.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        event.preventDefault();
        closeDialog();
        return;
      }

      if (event.key === 'Tab') {
        const focusable = [closeButton, video].filter((element): element is HTMLButtonElement | HTMLVideoElement => Boolean(element && element.tabIndex >= 0));
        if (!focusable.length) return;

        const first = focusable[0]!;
        const last = focusable[focusable.length - 1]!;
        const currentIndex = focusable.indexOf(document.activeElement as HTMLButtonElement | HTMLVideoElement);
        const next = event.shiftKey
          ? (currentIndex <= 0 ? last : focusable[currentIndex - 1]!)
          : (currentIndex < 0 || currentIndex === focusable.length - 1 ? first : focusable[currentIndex + 1]!);
        event.preventDefault();
        next.focus();
      }
    });
    dialog.addEventListener('cancel', (event) => {
      event.preventDefault();
      closeDialog();
    });
    dialog.addEventListener('close', () => {
      video?.pause();
      openButton?.focus();
    });
  });
</script>
