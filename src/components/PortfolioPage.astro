---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import type { PortfolioContent } from '../data/portfolio';
interface Props { content: PortfolioContent; lang: 'zh' | 'ja'; }
const { content: portfolio, lang } = Astro.props;
const assetVersion = import.meta.env.PUBLIC_ASSET_VERSION || 'local';
const imageUrl = (src: string) => `${import.meta.env.BASE_URL}${src.slice(1)}?v=${assetVersion}`;
const featuredProjects = [5, 3, 4, 0]
  .map((index) => portfolio.projects.items[index])
  .filter(Boolean)
  .map((item) => item.homepageFeature ? { ...item, ...item.homepageFeature } : item);
const worksHref = `${import.meta.env.BASE_URL}${lang}/works/`;
---
<BaseLayout title={portfolio.meta.title} description={portfolio.meta.description} lang={lang === 'zh' ? 'zh-Hant' : 'ja'} skipLabel={portfolio.ui.skipToContent}>
  <Header content={portfolio} lang={lang} />
  <main id="main-content">
    <section class="hero" id="top" aria-labelledby="hero-title">
      <img class="hero-image" src={imageUrl(portfolio.hero.image.src)} alt={portfolio.hero.image.alt} width="1600" height="1100" fetchpriority="high" />
      <div class="hero-shade"></div>
      <div class="shell hero-inner">
        <div class="hero-copy">
          <p class="kicker">{portfolio.hero.eyebrow}</p>
          <h1 id="hero-title">{portfolio.hero.title}</h1>
          <p>{portfolio.hero.description}</p>
          <div class="hero-actions">
            <a class="pill light-pill" href={portfolio.hero.primaryAction.href}>{portfolio.hero.primaryAction.label}<span aria-hidden="true">↓</span></a>
            <a class="pill hero-outline" href={portfolio.hero.secondaryAction.href}>{portfolio.hero.secondaryAction.label}<span aria-hidden="true">→</span></a>
          </div>
        </div>
        <ul class="hero-highlights" aria-label={portfolio.hero.note}>
          {portfolio.hero.highlights.map((item) => <li><span>{item.label}</span><strong>{item.value}</strong></li>)}
        </ul>
      </div>
    </section>

    <section class="start-here section" id="start-here" aria-labelledby="start-title">
      <div class="shell">
        <div class="section-heading-simple"><p class="section-tag">{portfolio.startHere.label}</p><h2 id="start-title">{portfolio.startHere.title}</h2></div>
        <div class="entry-grid">
          {portfolio.startHere.items.map((item) => <article class="entry-card">
            <span class="entry-number" aria-hidden="true">{item.number}</span><h3>{item.title}</h3><p>{item.description}</p><a href={item.action.href}>{item.action.label}<span aria-hidden="true"> →</span></a>
          </article>)}
        </div>
        <p class="section-afterword">{portfolio.startHere.intro}</p>
      </div>
    </section>

    <section class="about section" id="about" aria-labelledby="about-title">
      <div class="shell about-grid">
        <figure class="about-photo"><img src={imageUrl(portfolio.about.image.src)} alt={portfolio.about.image.alt} width="900" height="1100" loading="lazy" decoding="async" /></figure>
        <div class="about-copy">
          <p class="section-tag">{portfolio.about.label}</p>
          <h2 id="about-title">{portfolio.about.title}</h2>
          {portfolio.about.paragraphs.map((text) => <p>{text}</p>)}
          <blockquote class="about-story">{portfolio.about.story}</blockquote>
          <a class="pill outline-pill" href="#portfolio">{portfolio.ui.learnStory} <span aria-hidden="true">→</span></a>
        </div>
        <ul class="about-points" aria-label="Focus areas">
          {portfolio.about.facts.map((item, i) => <li><span class="line-icon" aria-hidden="true">{['♩','♧','◎'][i]}</span><div><h3>{item.value}</h3><p>{item.label}</p></div></li>)}
        </ul>
        <div class="about-values">
          {portfolio.values.items.map((item) => <article><h3>{item.title}</h3><p>{item.description}</p></article>)}
        </div>
        <ol class="about-timeline">{portfolio.about.timeline.map((item) => <li><span>{item.label}</span><h3>{item.title}</h3><p>{item.description}</p></li>)}</ol>
      </div>
    </section>

    <section class="currently section tinted" id="currently" aria-labelledby="currently-title">
      <div class="shell currently-layout"><div><p class="section-tag">{portfolio.currently.label}</p><h2 id="currently-title">{portfolio.currently.title}</h2><p>{portfolio.currently.intro}</p></div><div class="currently-list">{portfolio.currently.items.map((item) => <article><span>{item.status}</span><h3>{item.title}</h3><p>{item.description}</p></article>)}</div></div>
    </section>

    <section class="services section" id="services" aria-labelledby="services-title">
      <div class="shell">
        <p class="section-tag">{portfolio.services.label}</p><h2 id="services-title">{portfolio.services.title}</h2>
        <div class="service-grid">
          {portfolio.services.items.map((item) => <article class="service-card" id={`service-${item.number}`}>
            <div class="service-photo"><img src={imageUrl(item.image.src)} alt={item.image.alt} width="1440" height="900" loading="lazy" decoding="async" /><span class="icon-badge" aria-hidden="true">{item.number}</span></div><p class="service-status">{item.status}</p>
            <h3>{item.title}</h3><p>{item.description}</p><p class="service-audience"><strong>{portfolio.ui.suitableFor}</strong>{item.audience}</p><a href={item.action.href}>{item.action.label} <span aria-hidden="true">→</span></a>
          </article>)}
        </div>
        <p class="section-afterword">{portfolio.services.intro}</p>
      </div>
    </section>

    <section class="projects section tinted" id="portfolio" aria-labelledby="projects-title">
      <div class="shell">
        <div class="section-heading-simple"><p class="section-tag">{portfolio.projects.label}</p><h2 id="projects-title">{portfolio.projects.title}</h2></div>
        <ProjectGrid items={featuredProjects} content={portfolio} showLatestExploration />
        <div class="projects-footer"><a class="pill outline-pill projects-all" href={worksHref}>{portfolio.projects.allAction} <span aria-hidden="true">→</span></a><p class="section-afterword">{portfolio.projects.intro}</p></div>
      </div>
    </section>

    <section class="testimonials section tinted" id="testimonials" aria-labelledby="testimonials-title">
      <div class="shell">
        <p class="section-tag">{portfolio.testimonials.label}</p><h2 id="testimonials-title">{portfolio.testimonials.title}</h2>
        <div class={`quote-grid quote-count-${portfolio.testimonials.items.length}`}>{portfolio.testimonials.items.map((item, i) => <article class="outcome-card"><span class="quote-number" aria-hidden="true">0{i + 1}</span><h3>{item.role}</h3><p>{item.quote}</p></article>)}</div>
      </div>
    </section>

    <section class="process section" id="process" aria-labelledby="process-title">
      <div class="shell process-grid">
        <figure class="process-image"><img src={imageUrl(portfolio.process.image.src)} alt={portfolio.process.image.alt} width="1280" height="960" loading="lazy" decoding="async" /></figure>
        <div><p class="section-tag">{portfolio.process.label}</p><h2 id="process-title">{portfolio.process.title}</h2><p class="process-note">{portfolio.process.note}</p>
        <ol class="process-list">{portfolio.process.items.map((item, i) => <li><span>0{i + 1}</span><div><h3>{item.title}</h3><p>{item.description}</p></div></li>)}</ol></div>
      </div>
    </section>

    {portfolio.journal.enabled && <section class="journal-preview section tinted" aria-labelledby="journal-title"><div class="shell"><div class="section-heading-simple"><p class="section-tag">{portfolio.journal.label}</p><h2 id="journal-title">{portfolio.journal.title}</h2></div><div class="journal-grid">{portfolio.journal.items.map((item) => <article><div class="journal-image"><img src={imageUrl(item.image.src)} alt={item.image.alt} width="900" height="600" loading="lazy" decoding="async" /></div><div class="journal-body"><div><span>{item.category}</span><time>{item.date}</time></div><h3>{item.title}</h3><p>{item.excerpt}</p></div></article>)}</div></div></section>}

    <section class="contact" id="contact" aria-labelledby="contact-title">
      <div class="contact-visual"><img src={imageUrl(portfolio.contact.image.src)} alt={portfolio.contact.image.alt} width="1829" height="864" loading="lazy" decoding="async" /></div>
      <div class="shell contact-form-grid">
        <div class="contact-title"><p class="section-tag">{portfolio.contact.label}</p><h2 id="contact-title">{portfolio.contact.title}</h2></div>
        <form class="contact-form" id="contact-form" data-email={portfolio.contact.email} data-subject={portfolio.contact.form.subject}>
          <p class="contact-encouragement">{portfolio.contact.encouragement}</p>
          <label>{portfolio.contact.form.name}<input name="name" autocomplete="name" required /></label>
          <label>{portfolio.contact.form.email}<input name="email" type="email" autocomplete="email" required /></label>
          <label class="form-wide">{portfolio.contact.form.topic}<input name="topic" required /></label>
          <label class="form-wide">{portfolio.contact.form.message}<textarea name="message" rows="4" required></textarea></label>
          <button class="pill light-pill" type="submit">{portfolio.contact.form.submit} <span aria-hidden="true">→</span></button>
        </form>
        <div class="contact-afterword"><p>{portfolio.contact.description}</p><a class="contact-follow" href={portfolio.contact.socialLinks[0].href} target="_blank" rel="noreferrer">{portfolio.contact.secondaryAction} ↗</a></div>
      </div>
    </section>
  </main>
  <Footer content={portfolio} />
  <script>
    document.querySelector<HTMLFormElement>('#contact-form')?.addEventListener('submit', (event) => {
      event.preventDefault();
      const form = event.currentTarget as HTMLFormElement;
      const data = new FormData(form);
      const body = [`Name: ${data.get('name')}`, `Email: ${data.get('email')}`, `Topic: ${data.get('topic')}`, '', String(data.get('message'))].join('\n');
      window.location.href = `mailto:${form.dataset.email}?subject=${encodeURIComponent(form.dataset.subject || '')}&body=${encodeURIComponent(body)}`;
    });
  </script>
</BaseLayout>
