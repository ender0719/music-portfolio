---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { PortfolioContent } from '../data/portfolio';
interface Props { content: PortfolioContent; lang: 'zh' | 'ja'; }
const { content: portfolio, lang } = Astro.props;
const imageUrl = (src: string) => `${import.meta.env.BASE_URL}${src.slice(1)}`;
---
<BaseLayout title={portfolio.meta.title} description={portfolio.meta.description} lang={lang === 'zh' ? 'zh-Hant' : 'ja'} skipLabel={portfolio.ui.skipToContent}>
  <Header content={portfolio} lang={lang} />
  <main id="main-content">
    <section class="hero" id="top" aria-labelledby="hero-title">
      <img class="hero-image" src={imageUrl(portfolio.hero.image.src)} alt={portfolio.hero.image.alt} width="1600" height="1100" fetchpriority="high" />
      <div class="hero-shade"></div>
      <div class="shell hero-inner">
        <div class="hero-copy">
          <p class="kicker">{portfolio.hero.eyebrow}</p>
          <h1 id="hero-title">{portfolio.hero.title}</h1>
          <p>{portfolio.hero.description}</p>
          <div class="hero-actions">
            <a class="pill light-pill" href={portfolio.hero.primaryAction.href}>{portfolio.hero.primaryAction.label}<span aria-hidden="true">↓</span></a>
            <a class="pill hero-outline" href={portfolio.hero.secondaryAction.href}>{portfolio.hero.secondaryAction.label}<span aria-hidden="true">→</span></a>
          </div>
        </div>
        <ul class="hero-highlights" aria-label={portfolio.hero.note}>
          {portfolio.hero.highlights.map((item) => <li><span>{item.label}</span><strong>{item.value}</strong></li>)}
        </ul>
      </div>
    </section>

    <section class="start-here section" id="start-here" aria-labelledby="start-title">
      <div class="shell">
        <div class="section-heading-row"><div><p class="section-tag">{portfolio.startHere.label}</p><h2 id="start-title">{portfolio.startHere.title}</h2></div><p>{portfolio.startHere.intro}</p></div>
        <div class="entry-grid">
          {portfolio.startHere.items.map((item) => <article class="entry-card">
            <span class="entry-number" aria-hidden="true">{item.number}</span><h3>{item.title}</h3><p>{item.description}</p><a href={item.action.href}>{item.action.label}<span aria-hidden="true"> →</span></a>
          </article>)}
        </div>
      </div>
    </section>

    <section class="about section" id="about" aria-labelledby="about-title">
      <div class="shell about-grid">
        <figure class="about-photo"><img src={imageUrl(portfolio.about.image.src)} alt={portfolio.about.image.alt} width="900" height="1100" loading="lazy" decoding="async" /></figure>
        <div class="about-copy">
          <p class="section-tag">{portfolio.about.label}</p>
          <h2 id="about-title">{portfolio.about.title}</h2>
          {portfolio.about.paragraphs.map((text) => <p>{text}</p>)}
          <a class="pill outline-pill" href="#portfolio">{portfolio.ui.learnStory} <span aria-hidden="true">→</span></a>
        </div>
        <ul class="about-points" aria-label="Focus areas">
          {portfolio.about.facts.map((item, i) => <li><span class="line-icon" aria-hidden="true">{['♩','♧','◎'][i]}</span><div><h3>{item.value}</h3><p>{item.label}</p></div></li>)}
        </ul>
      </div>
    </section>

    <section class="values section tinted" id="why-music" aria-labelledby="values-title">
      <div class="shell">
        <div class="section-heading-row"><div><p class="section-tag">{portfolio.values.label}</p><h2 id="values-title">{portfolio.values.title}</h2></div><p>{portfolio.values.intro}</p></div>
        <div class="value-grid">{portfolio.values.items.map((item) => <article class="value-card"><span aria-hidden="true">{item.number}</span><h3>{item.title}</h3><p>{item.description}</p></article>)}</div>
      </div>
    </section>

    <section class="services section" id="services" aria-labelledby="services-title">
      <div class="shell">
        <p class="section-tag">{portfolio.services.label}</p><h2 id="services-title">{portfolio.services.title}</h2><p class="section-intro">{portfolio.services.intro}</p>
        <div class="service-grid">
          {portfolio.services.items.map((item) => <article class="service-card" id={`service-${item.number}`}>
            <div class="service-photo"><img src={imageUrl(item.image.src)} alt={item.image.alt} width="1440" height="900" loading="lazy" decoding="async" /><span class="icon-badge" aria-hidden="true">{item.number}</span></div>
            <h3>{item.title}</h3><p>{item.description}</p><p class="service-audience"><strong>{portfolio.ui.suitableFor}</strong>{item.audience}</p><a href={item.action.href}>{item.action.label} <span aria-hidden="true">→</span></a>
          </article>)}
        </div>
      </div>
    </section>

    <section class="projects section tinted" id="portfolio" aria-labelledby="projects-title">
      <div class="shell">
        <div class="section-heading-row"><div><p class="section-tag">{portfolio.projects.label}</p><h2 id="projects-title">{portfolio.projects.title}</h2></div><p>{portfolio.projects.intro}</p></div>
        <div class="project-grid">
          {portfolio.projects.items.map((item, i) => <article class={`project-card project-${i + 1}`}>
            <div class="project-image"><img src={imageUrl(item.image.src)} alt={item.image.alt} width="1024" height="768" loading="lazy" decoding="async" /><span>0{i + 1}</span></div>
            <div class="project-body"><div class="project-tags">{item.tags.map((tag) => <span>{tag}</span>)}</div><h3>{item.title}</h3><p>{item.description}</p><dl class="project-details"><div><dt>{portfolio.ui.role}</dt><dd>{item.role}</dd></div><div><dt>{portfolio.ui.takeaway}</dt><dd>{item.insight}</dd></div></dl>{item.link && <a href={item.link} target="_blank" rel="noreferrer">{portfolio.ui.learnMore} ↗</a>}</div>
          </article>)}
        </div>
      </div>
    </section>

    <section class="testimonials section tinted" id="testimonials" aria-labelledby="testimonials-title">
      <div class="shell">
        <p class="section-tag">{portfolio.testimonials.label}</p><h2 id="testimonials-title">{portfolio.testimonials.title}</h2>
        <div class="quote-grid">{portfolio.testimonials.items.map((item) => <figure><blockquote>「{item.quote}」</blockquote><figcaption>{item.role}</figcaption></figure>)}</div>
      </div>
    </section>

    <section class="process section" id="process" aria-labelledby="process-title">
      <div class="shell process-grid">
        <figure class="process-image"><img src={imageUrl(portfolio.process.image.src)} alt={portfolio.process.image.alt} width="1280" height="960" loading="lazy" decoding="async" /></figure>
        <div><p class="section-tag">{portfolio.process.label}</p><h2 id="process-title">{portfolio.process.title}</h2>
        <ol class="process-list">{portfolio.process.items.map((item, i) => <li><span>0{i + 1}</span><div><h3>{item.title}</h3><p>{item.description}</p></div></li>)}</ol></div>
      </div>
    </section>

    <section class="vision" id="vision" aria-labelledby="vision-title">
      <img src={imageUrl(portfolio.vision.image.src)} alt={portfolio.vision.image.alt} width="1920" height="800" loading="lazy" decoding="async" />
      <div class="vision-shade"></div>
      <div class="shell vision-copy"><p class="section-tag">{portfolio.vision.label}</p><h2 id="vision-title">{portfolio.vision.title}</h2><blockquote>{portfolio.vision.quote}</blockquote><p>{portfolio.vision.description}</p><a class="pill dark-outline" href="#contact">{portfolio.ui.learnMore} <span aria-hidden="true">→</span></a></div>
    </section>

    <section class="contact" id="contact" aria-labelledby="contact-title">
      <div class="contact-visual"><img src={imageUrl(portfolio.contact.image.src)} alt={portfolio.contact.image.alt} width="1829" height="864" loading="lazy" decoding="async" /></div>
      <div class="shell contact-grid">
        <div class="contact-title"><p class="section-tag">{portfolio.contact.label}</p><h2 id="contact-title">{portfolio.contact.title}</h2><p>{portfolio.contact.description}</p><div class="contact-actions"><a class="pill light-pill" href={`mailto:${portfolio.contact.email}`}>{portfolio.contact.primaryAction}</a><a href={portfolio.contact.socialLinks[0].href} target="_blank" rel="noreferrer">{portfolio.contact.secondaryAction} ↗</a></div></div>
        <div class="contact-card"><span aria-hidden="true">01</span><div><h3>{portfolio.ui.message}</h3><p>{portfolio.ui.messageDescription}</p><a href={`mailto:${portfolio.contact.email}`}>{portfolio.ui.message} →</a></div></div>
        <div class="contact-card"><span aria-hidden="true">02</span><div><h3>{portfolio.ui.follow}</h3><p>{portfolio.ui.followDescription}</p><a href={portfolio.contact.socialLinks[0].href} target="_blank" rel="noreferrer">Instagram →</a></div></div>
        <div class="contact-card"><span aria-hidden="true">03</span><div><h3>{portfolio.ui.collaborate}</h3><p>{portfolio.ui.collaborateDescription}</p><a href={`mailto:${portfolio.contact.email}`}>Email →</a></div></div>
      </div>
    </section>
  </main>
  <Footer content={portfolio} />
</BaseLayout>
